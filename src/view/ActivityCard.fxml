<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="8.0" style="-fx-background-color: #ccff00; -fx-background-radius: 12;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ActivityCardController">
   <children>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label fx:id="activityNameLabel" text="Activity name">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <ImageView fx:id="editBtn" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#handleEdit" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../resources/edit.png" />
               </image>
            </ImageView>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="30.0">
         <children>
            <Label fx:id="mapLabel" text="Map:" />
            <Label fx:id="avgSpeedLabel" text="Avg Speed:" />
            <Label fx:id="distanceLabel" text="Distance:" />
            <Label fx:id="elevationLabel" text="Elevation:" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="deleteLabel" style="-fx-icon-code: bi-trash" />
            <ImageView fx:id="deletBtn" fitHeight="25.0" fitWidth="25.0" onMouseClicked="#handleDelete" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../resources/trash.png" />
               </image>
            </ImageView>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
   </padding>
</VBox>
