<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

    <!-- ===== LEFT SIDEBAR ===== -->
    <left>
        <VBox prefWidth="240" style="-fx-background-color: #1a1a1a;">

            <!-- User header -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 24 20 24 20;">
                <Circle fx:id="avatarCircle" radius="32" style="-fx-fill: #c8f020; -fx-stroke: #c8f020; -fx-stroke-width: 2;" />
                <VBox spacing="2">
                    <Label fx:id="labelName" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;" text="Name" />
                    <Label fx:id="labelSurname" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="Surname" />
                </VBox>
            </HBox>

            <!-- Separator -->
            <Region prefHeight="1" style="-fx-background-color: #333333;" />

            <!-- Nav buttons — plain, no icons -->
            <VBox spacing="0" style="-fx-padding: 20 0 0 0;">

                <Button fx:id="btnProfile" onAction="#handleProfile" onMouseClicked="#profileClick" prefHeight="48" prefWidth="240" style="-fx-background-color: transparent; -fx-text-fill: #cccccc;                                -fx-font-size: 15px; -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" text="Profile" />

                <Button fx:id="btnActivities" onAction="#handleActivities" onMouseClicked="#activitiesClick" prefHeight="48" prefWidth="240" style="-fx-background-color: transparent; -fx-text-fill: #cccccc;                                -fx-font-size: 15px; -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" text="Activities" />

                <Button fx:id="btnMaps" onAction="#handleMaps" onMouseClicked="#mapClick" prefHeight="48" prefWidth="240" style="-fx-background-color: transparent; -fx-text-fill: #cccccc;                                -fx-font-size: 15px; -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" text="Map" />

                <Button fx:id="btnDashboard" onAction="#handleDashboard" prefHeight="48" prefWidth="240" style="-fx-background-color: #2d2d2d; -fx-text-fill: white;                                -fx-font-size: 15px; -fx-font-weight: bold;                                -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 24;                                -fx-cursor: hand; -fx-border-color: transparent;" text="Dashboard" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Region prefHeight="1" style="-fx-background-color: #333333;" />

            <Button fx:id="btnLogout" onAction="#handleLogOut" onMouseClicked="#logOutClick" prefHeight="48" prefWidth="240" style="-fx-background-color: transparent; -fx-text-fill: #cccccc;                            -fx-font-size: 15px; -fx-alignment: CENTER_LEFT;                            -fx-padding: 0 0 0 24; -fx-cursor: hand; -fx-border-color: transparent;" text="Log out" />
        </VBox>
    </left>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <VBox style="-fx-background-color: white;">

            <!-- Title bar -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 28 40 20 40;">
                <Label style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="DASHBOARD" />
                <Region HBox.hgrow="ALWAYS" />
            <ImageView fitHeight="99.0" fitWidth="110.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../../Imágenes/Capturas%20de%20pantalla/Screenshot%202026-05-13%20090839.png" />
               </image>
            </ImageView>
            </HBox>

            <!-- Two-column body -->
            <HBox spacing="24" style="-fx-padding: 0 40 30 40;" VBox.vgrow="ALWAYS">

                <!-- ── LEFT: Map panel ── -->
                <VBox spacing="0" style="-fx-background-color: #c8f020; -fx-background-radius: 14px;                              -fx-padding: 12;">
               <HBox prefHeight="44.0" prefWidth="444.0">
                  <children>
                           <Button fx:id="btnAddAnnotations" onAction="#diagAddAnnotations" onMouseClicked="#addAnnotationsClick" prefHeight="37.0" prefWidth="174.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white;                                        -fx-font-size: 13px; -fx-font-weight: bold;                                        -fx-padding: 9 16 9 16; -fx-background-radius: 6px;                                        -fx-cursor: hand;" text="Add Annotations" />
                     <Region prefHeight="59.0" prefWidth="193.0" />
                           <Button fx:id="btnSelectMap" onAction="#handleSelectMap" onMouseClicked="#selectMapClick" prefHeight="37.0" prefWidth="121.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white;                                        -fx-font-size: 13px; -fx-font-weight: bold;                                        -fx-padding: 9 16 9 16; -fx-background-radius: 6px;                                        -fx-cursor: hand;" text="Select map" />
                  </children>
               </HBox>

                    <!-- Map toolbar -->
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 10 0;">
                  <Label prefHeight="17.0" prefWidth="74.0" text="   Zoom">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <Button fx:id="btnZoomOut" mnemonicParsing="false" text="-">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Slider fx:id="zoomSlider" prefHeight="14.0" prefWidth="263.0" />
                  <Button fx:id="btnZoomIn" mnemonicParsing="false" text="+">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                    </HBox>

                    <!-- Map area -->
                    <ScrollPane fx:id="mapScrollPane" fitToHeight="true" fitToWidth="true" prefHeight="474.0" prefWidth="445.0" style="-fx-background: #dddddd; -fx-background-color: #dddddd;                                        -fx-border-color: transparent; -fx-background-radius: 10px;">
                  <content>
                     <StackPane fx:id="mapContainer" prefHeight="150.0" prefWidth="200.0">
                        <children>
                           <ImageView fx:id="mapImageView" fitHeight="590.0" fitWidth="872.0" pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@../../maps/calderona.jpg" />
                              </image>
                           </ImageView>
                           <Pane fx:id="annotationsPane" pickOnBounds="false" prefHeight="564.0" prefWidth="745.0" />
                        </children>
                     </StackPane>
                  </content>
                    </ScrollPane>
                </VBox>

                <!-- ── RIGHT: Stats + buttons + chart ── -->
                <VBox spacing="16" HBox.hgrow="ALWAYS">

                    <!-- Statistics panel -->
                    <VBox spacing="0" style="-fx-background-color: #c8f020; -fx-background-radius: 12px;                                  -fx-padding: 14 16 14 16;">
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;                                       -fx-text-fill: #111111; -fx-padding: 0 0 10 0;" text="Statistics" />

                        <GridPane hgap="20" vgap="5">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="155" />
                                <ColumnConstraints prefWidth="155" />
                            </columnConstraints>

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Duration:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="lblDuration" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Distance:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <Label fx:id="lblDistance" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Average pace:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <Label fx:id="lblAvgPace" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Average speed:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                            <Label fx:id="lblAvgSpeed" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Max altitude:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                            <Label fx:id="lblMaxAltitude" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Min altitude:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                            <Label fx:id="lblMinAltitude" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Max elevation:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                            <Label fx:id="lblMaxElevation" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #111111;" text="Min elevation:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                            <Label fx:id="lblMinElevation" style="-fx-font-size: 13px; -fx-text-fill: #111111;" text="" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                     <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                     </rowConstraints>
                        </GridPane>
                    </VBox>

                    <!-- Speed / Elevation profile buttons inside lime panel -->
                    <HBox spacing="14" style="-fx-background-color: #c8f020; -fx-background-radius: 12px;                                  -fx-padding: 14 16 14 16;">
                        <Button fx:id="btnSpeedRoute" onAction="#handleSpeedOverRoute" onMouseClicked="#speedOverRouteClick" prefHeight="28.0" prefWidth="175.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white;                                        -fx-font-size: 13px; -fx-font-weight: bold;                                        -fx-background-radius: 10px; -fx-cursor: hand;                                        -fx-text-alignment: center;" text="Speed over the route" />
                        <Button fx:id="btnElevationProfile" onAction="#handleElevationProfile" onMouseClicked="#elevationProfileClick" prefHeight="28.0" prefWidth="168.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white;                                        -fx-font-size: 13px; -fx-font-weight: bold;                                        -fx-background-radius: 10px; -fx-cursor: hand;                                        -fx-text-alignment: center;" text="Elevation profile" />
                    </HBox>

                    <!-- Elevation chart inside lime-bordered panel -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 12px;                                  -fx-border-color: #c8f020; -fx-border-width: 3px;                                  -fx-border-radius: 12px; -fx-padding: 10;" VBox.vgrow="ALWAYS">
                        <Canvas fx:id="elevationCanvas" height="210" width="360" />
                    </VBox>

                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>
