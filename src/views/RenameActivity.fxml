<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefWidth="360.0" spacing="18.0" style="-fx-background-color: #3a363d; -fx-background-radius: 16;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.RenameActivityController">
   <children>
      <Label text="Rename Activity" textFill="WHITE">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
      <TextField fx:id="newNameField" promptText="New name" style="-fx-background-radius: 20; -fx-padding: 12 16 12 16;">
         <font>
            <Font size="14.0" />
         </font>
      </TextField>
      <Button fx:id="submitButton" mnemonicParsing="false" onAction="#handleSubmit" style="-fx-background-color: white; -fx-text-fill: black; -fx-background-radius: 8; -fx-padding: 10 30 10 30;" text="Submit">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
         <VBox.margin>
            <Insets top="20.0" />
         </VBox.margin>
      </Button>
   </children>
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
   </padding>
</VBox>
